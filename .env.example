# Twitch Configuration
# TWITCH_CLIENT_ID is optional — defaults to the public Visema app.
# Set only if you fork with your own Twitch app:
# TWITCH_CLIENT_ID=your_client_id_here

# IMPORTANT: Get your BROADCASTER_ID (numeric channel ID, not username!)
# Find it at: https://www.streamweasels.com/tools/convert-twitch-username-to-user-id/
TWITCH_BROADCASTER_ID=
