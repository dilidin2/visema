# Twitch app credentials (from dev.twitch.tv)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# OAuth tokens — populated automatically by auth.py on first run.
# On first launch, the bot opens a browser for you to authorize BOTH accounts:
#   1. Broadcaster account (channel points access)
#   2. Bot account (chat messaging)
# After authorizing, tokens are saved here automatically. No manual copy-paste needed.
BROADCASTER_ACCESS_TOKEN=
BROADCASTER_REFRESH_TOKEN=
BOT_ACCESS_TOKEN=
BOT_REFRESH_TOKEN=
